meta {
  name: Get Operation Request History
  type: http
  seq: 17
}

get {
  url: {{baseUrl}}/api/operation-requests/{{operationRequestId}}/history
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{operatorToken}}
}

tests {
  test("get operation request history returns 200", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body.operation_request_history_entries).to.be.an("array");
  });
}
