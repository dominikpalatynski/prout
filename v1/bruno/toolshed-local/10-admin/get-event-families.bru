meta {
  name: Get Event Families
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/event-families
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{operatorToken}}
}

tests {
  test("event families returns 200", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body.event_families).to.be.an("array");
  });
}
