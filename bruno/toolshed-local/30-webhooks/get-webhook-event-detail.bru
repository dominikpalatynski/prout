meta {
  name: Get Webhook Event Detail
  type: http
  seq: 16
}

get {
  url: {{baseUrl}}/api/webhook-events/{{webhookEventId}}
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{operatorToken}}
}

tests {
  test("get webhook event detail returns 200", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body.webhook_event.id).to.equal(Number(bru.getEnvVar("webhookEventId")));
  });
}
