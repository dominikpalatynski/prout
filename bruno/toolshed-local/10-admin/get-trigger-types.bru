meta {
  name: Get Trigger Types
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/trigger-types
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{operatorToken}}
}

vars:pre-request {
  baseUrl: http://localhost:8080
  operatorToken: U5cC1PhGSuD230l0vsEyBib0ztH40iSqO1OUTfDYCaU=
}

tests {
  test("trigger types returns 200", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body.trigger_types).to.be.an("array");
  });
}
